name: Sport Booking Bot

on:
  schedule:
    # 17h30 UTC = 19h30 Paris (Heure d'été)
    - cron: '30 17 * * *'
  workflow_dispatch: # Permet de lancer le test manuellement depuis l'onglet Actions

jobs:
  book:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm' # Accélère les lancements futurs

      - name: Install dependencies
        run: npm ci || npm install # npm ci est plus strict, on met un fallback au cas où

      - name: Install Playwright Browsers
        # On utilise 'npx playwright' directement, GitHub gère généralement bien les droits
        # si les dossiers 'node_modules' ne sont pas poussés manuellement.
        run: npx playwright install chromium --with-deps

      - name: Run Playwright tests
        run: npx playwright test
        env:
          USER_EMAIL: ${{ secrets.USER_EMAIL }}
          USER_PASSWORD: ${{ secrets.USER_PASSWORD }}