import { test } from '@playwright/test';

/**
 * 1. CONFIGURATION DU PLANNING
 * Index : 0=Dimanche, 1=Lundi, ..., 6=Samedi
 */
const MY_SCHEDULE: { [key: number]: { name: string, time: string }[] } = {
  1: [{ name: "Body Sculpt", time: "12:15" }, { name: "LM Core", time: "19:15" }],
  2: [{ name: "100% fessiers", time: "18:30" }],
  3: [{ name: "TRX Circuit", time: "19:00" }],
  4: [{ name: "Cardio sculpt", time: "18:45" }],
  5: [{ name: "Yoga Vinyasa niveau avancé", time: "12:15" }, { name: "Yoga Vinyasa niveau avancé", time: "18:15" }],
  6: [{ name: "Yoga Vinyasa niveau avancé", time: "13:30" }, { name: "Méditation", time: "14:30" }],
};


test.setTimeout(90000);

test('Inscription Automatique Sport J+8', async ({ page }) => {
  // --- PRÉPARATION DE LA DATE CIBLE (J+8) ---
  const targetDate = new Date();
  targetDate.setDate(targetDate.getDate() + 8);
  const isoDate = targetDate.toISOString().split('T')[0]; // Format YYYY-MM-DD
  const dayOfWeek = targetDate.getDay(); 
  const daysFrench = ["Dimanche", "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi", "Samedi"];

  const coursesToBook = MY_SCHEDULE[dayOfWeek];

  console.log(`🚀 Lancement du bot pour le ${daysFrench[dayOfWeek]} ${targetDate.toLocaleDateString('fr-FR')}`);

  if (!coursesToBook || coursesToBook.length === 0) {
    console.log("ℹ️ Aucun cours configuré pour ce jour-là.");
    return;
  }

  // --- 2. CONNEXION ---
  await page.goto('https://member.resamania.com/lscfitnforme/login');
  await page.fill('#login_step_login_username', process.env.USER_EMAIL!);
  await page.click('#login_step_login_submit');
  
  await page.waitForSelector('#_password', { state: 'visible' });
  await page.fill('#_password', process.env.USER_PASSWORD!);
  await page.click('#submit');
  
  await page.waitForLoadState('networkidle');
  console.log("✅ Connexion réussie !");

  // --- 3. BOUCLE SUR LES COURS DU JOUR ---
  for (const courseConfig of coursesToBook) {
    console.log(`\n🔍 Tentative pour : ${courseConfig.name} à ${courseConfig.time}`);
    
    const targetUrl = `https://member.resamania.com/lscfitnforme/planning?club=%2Flscfitnforme%2Fclubs%2F985&startedAt=${isoDate}`;
    
    let isBooked = false;
    const startTime = Date.now();
    const maxDuration = 60000; // Le bot essaiera de rafraîchir pendant 60 secondes max

    while (Date.now() - startTime < maxDuration) {
      await page.goto(targetUrl);
      await page.waitForLoadState('networkidle');

      // Identification de la carte spécifique au cours
      const courseCard = page.locator('.MuiPaper-root')
                             .filter({ hasText: courseConfig.time })
                             .filter({ hasText: new RegExp(courseConfig.name, 'i') })
                             .first();

      if (await courseCard.isVisible()) {
        const targetButton = courseCard.getByRole('button', { name: /inscrire/i });

        if (await targetButton.isVisible()) {
          const btnText = await targetButton.innerText();

          if (btnText.toUpperCase().includes("DÉSINSCRIRE")) {
            console.log(`ℹ️ Déjà inscrit à ${courseConfig.name}.`);
            isBooked = true;
            break;
          }

          // Clic sur le bouton d'inscription de la carte
          await targetButton.click({ force: true });

          // Gestion de la modale de confirmation finale
          const confirmBtn = page.locator('button').filter({ hasText: /CONFIRMER|S'INSCRIRE|VALIDER/i }).last();
          
          try {
            await confirmBtn.waitFor({ state: 'visible', timeout: 5000 });
            await confirmBtn.click();
            console.log(`🎉 SUCCÈS : Inscription validÉE pour ${courseConfig.name} !`);
            isBooked = true;
            break; // Sort de la boucle 'while' pour passer au cours suivant
          } catch (e) {
            console.log("⚠️ Modale de confirmation non détectée.");
          }
        }
      }
      
      // Si le bouton n'est pas encore là (ex: il est 18h59m59s), on attend 1s et on rafraîchit
      console.log("⏳ Bouton non disponible, nouvel essai...");
      await page.waitForTimeout(1000); 
    }

    if (!isBooked) console.log(`❌ Échec final pour ${courseConfig.name} après 1 minute d'essais.`);
  }
});